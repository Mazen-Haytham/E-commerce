generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["catalog", "orders", "users", "public"]
}

model User {
  id           String       @id @default(uuid())
  email        String
  firstName    String
  lastName     String
  password     String
  phone        String
  deletedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tokenVersion Int          @default(0)
  orders       Order[]
  cart         Cart?
  profile      UserProfile?
  roles        UserRole[]

  @@schema("users")
}

model UserProfile {
  userId          String   @id
  profilePic      String?
  loyaltyPoints   Int      @default(0)
  membership      String   @default("regular")
  recommendations Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])

  @@schema("users")
}

model Cart {
  id        Int        @id @default(autoincrement())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]

  @@schema("users")
}

model CartItem {
  id               String         @id @default(uuid())
  cartId           Int
  productVariantId String
  quantity         Int
  unitPrice        Decimal
  addedAt          DateTime       @default(now())
  cart             Cart           @relation(fields: [cartId], references: [id])
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])

  @@unique([cartId, productVariantId])
  @@schema("users")
}

model Role {
  id    Int        @id @default(autoincrement())
  name  String     @unique
  users UserRole[]

  @@schema("users")
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId Int
  role   Role   @relation(fields: [roleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, roleId])
  @@schema("users")
}

model Product {
  id         String            @id @default(uuid())
  name       String
  producer   String?
  isActive   Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  deletedAt  DateTime?
  pricing    Pricing[]
  categories ProductCategory[]
  variants   ProductVariant[]

  @@index([createdAt(sort: Desc), id(sort: Desc)], map: "idx_products_pagination", where: raw("(\"deletedAt\" IS NULL)"))
  @@schema("catalog")
}

model ProductVariant {
  id             String         @id @default(uuid())
  productId      String
  sku            String         @unique
  color          String?
  size           String?
  weight         String
  price          Decimal
  additionalInfo Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  pricing        Pricing[]
  product        Product        @relation(fields: [productId], references: [id])
  images         VariantImage[]
  orderItems     OrderItem[]
  cartItems      CartItem[]

  @@schema("catalog")
}

model VariantImage {
  id        String         @id @default(uuid())
  variantId String
  url       String
  altText   String?
  sortOrder Int?
  isPrimary Boolean        @default(false)
  createdAt DateTime       @default(now())
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@schema("catalog")
}

model Category {
  id        String            @id @default(uuid())
  name      String            @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  deletedAt DateTime?
  pricing   Pricing[]
  products  ProductCategory[]

  @@schema("catalog")
}

model ProductCategory {
  id         String   @id @default(uuid())
  productId  String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])

  @@unique([productId, categoryId])
  @@schema("catalog")
}

model Pricing {
  id               String          @id @default(uuid())
  discountType     String
  discountValue    Decimal
  startDate        DateTime
  endDate          DateTime
  productId        String?
  productVariantId String?
  categoryId       String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  category         Category?       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  product          Product?        @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@schema("catalog")
}

enum OrderStatus {
  pending
  confirmed
  stock_rejected
  cancelled

  @@schema("orders")
}

model Order {
  id         String      @id @default(uuid())
  userId     String
  totalPrice Decimal
  status     OrderStatus @default(pending)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  user       User        @relation(fields: [userId], references: [id])
  items      OrderItem[]
  payments   Payment[]

  @@schema("orders")
}

model OrderItem {
  id               String         @id @default(uuid())
  orderId          String
  productVariantId String
  quantity         Int
  unitPrice        Decimal
  order            Order          @relation(fields: [orderId], references: [id])
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])

  @@schema("orders")
}

model PaymentMethod {
  id       String    @id @default(uuid())
  name     String    @unique
  payments Payment[]

  @@schema("orders")
}

model Payment {
  id              String        @id @default(uuid())
  orderId         String
  paymentMethodId String
  amount          Decimal
  transactionId   String?
  status          String
  createdAt       DateTime      @default(now())
  order           Order         @relation(fields: [orderId], references: [id])
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  @@schema("orders")
}

model OutboxEvent {
  id            BigInt    @id @default(autoincrement())
  eventId       String    @unique @map("event_id") @db.Uuid
  aggregateId   String    @map("aggregate_id") @db.Uuid
  aggregateType String    @map("aggregate_type") @db.VarChar(50)
  eventType     String    @map("event_type") @db.VarChar(50)
  payload       Json
  status        String?   @default("PENDING") @db.VarChar(20)
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  publishedAt   DateTime? @map("published_at") @db.Timestamp(6)

  @@map("outbox_events")
  @@schema("public")
}

model ProcessedEvent {
  eventId      String    @map("event_id") @db.Uuid
  consumerName String    @map("consumer_name") @db.VarChar(100)
  processedAt  DateTime? @default(now()) @map("processed_at") @db.Timestamp(6)

  @@unique([eventId, consumerName], map: "processed_events_event_id_consumer_name_key")
  @@map("processed_events")
  @@schema("public")
}
